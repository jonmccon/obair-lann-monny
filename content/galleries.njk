---
layout: layouts/archive.njk
permalink: /galleries/
eleventyNavigation:
  key: Photos
  order: 6
---
{%- css %}{% include "public/css/photoswipe-gallery.css" %}{% endcss %}
{# PhotoSwipe base styles are emitted as a static asset from node_modules. #}
<link rel="stylesheet" href="/css/photoswipe.css">
<h1>Photo Galleries</h1>
<p>Jump to a gallery:</p>

<nav class="gallery-jump-nav" aria-label="Gallery sections">
  <ul class="gallery-jump-links">
    {%- for gallery in collections.galleries %}
      <li><a href="#gallery-{{ gallery.page.fileSlug }}">{{ gallery.data.title }}</a></li>
    {%- endfor %}
  </ul>
</nav>

{%- for gallery in collections.galleries %}
  <section class="gallery-section" id="gallery-{{ gallery.page.fileSlug }}">
    <header class="gallery-section-header">
      <h2>{{ gallery.data.title }}</h2>
      {% if gallery.data.description %}
        <p class="gallery-description">{{ gallery.data.description }}</p>
      {% endif %}
    </header>
    <div class="gallery-section-content">
      {{ gallery.templateContent | safe }}
    </div>
  </section>
{%- endfor %}
