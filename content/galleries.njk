---
layout: layouts/archive.njk
permalink: /galleries/
eleventyNavigation:
  key: Photos
  order: 6
---
{%- css %}{% include "public/css/photoswipe-gallery.css" %}{% endcss %}
<h1>Photo Galleries</h1>
<p>Browse by category.</p>

<div class="galleries-grid">
  {%- for category in photoCategories %}
    <article class="gallery-card">
      <a href="{{ category.url }}" class="gallery-card-link">
        <div class="gallery-card-image">
          {% image category.cover, category.title %}
        </div>
        <div class="gallery-card-content">
          <h2 class="gallery-card-title">{{ category.title }}</h2>
          <p class="gallery-card-description">{{ category.description }}</p>
        </div>
      </a>
    </article>
  {%- endfor %}
</div>
