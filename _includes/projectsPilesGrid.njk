{# Piled projects component with tag filtering #}
{# Displays projects as randomly stacked piles grouped by tags #}

<div class="projects-piles-container">
  {# Tag filter buttons #}
  <div class="tag-filter-bar">
    <button class="tag-filter-button active" data-tag="all">All Projects</button>
    {% set allTags = collections.projects | getAllTags | filterTagList | sort %}
    {% for tag in allTags %}
      <button class="tag-filter-button" data-tag="{{ tag | slugify }}">{{ tag }}</button>
    {% endfor %}
  </div>

  {# Projects piles grid #}
  <div class="projects-piles-grid">
    {% for post in collections.projects | reverse %}
      {# Gather images for this post #}
      {% set projectImages = [] %}
      {% for image in collections.images %}
        {% if image.url == post.url %}
          {% set projectImages = projectImages.concat([image]) %}
        {% endif %}
      {% endfor %}
      
        {% if projectImages.length > 0 %}
          {# Get tags for filtering #}
          {% set postTags = post.data.tags | filterTagList %}
          {% set wordCount = post.templateContent | wordCount %}
          {% set orderedImages = projectImages %}
          {% if post.data.pileOrder and post.data.pileOrder.length %}
            {% set orderedImages = [] %}
            {% for i in post.data.pileOrder %}
              {% set imageIndex = i | int %}
              {% if projectImages[imageIndex] %}
                {% set orderedImages = orderedImages.concat([projectImages[imageIndex]]) %}
              {% endif %}
            {% endfor %}
            {% for img in projectImages %}
              {% if not (loop.index0 in post.data.pileOrder) %}
                {% set orderedImages = orderedImages.concat([img]) %}
              {% endif %}
            {% endfor %}
          {% endif %}
          {% set tagClasses = "" %}
          {% for tag in postTags %}
            {% set tagClasses = tagClasses + " tag-" + (tag | slugify) %}
          {% endfor %}
        
        <div class="project-pile" data-tags="{{ tagClasses }}">
          <a href="{{ post.url }}" class="pile-link" data-project-link>
            <div class="pile-container">
              <div class="pile-images"
                   data-image-count="{{ orderedImages.length }}">
                {% for img in orderedImages | head(5) %}
                  <div class="pile-image"
                       data-layer-index="{{ loop.index0 }}"
                       style="--z-index: {{ 10 - loop.index0 }};">
                    <img src="{{ img.pileSrc or img.src }}"
                         alt="{{ img.alt or post.data.title }}"
                         width="{{ img.pileWidth or img.width }}"
                         height="{{ img.pileHeight or img.height }}"
                         loading="lazy"
                         decoding="async">
                  </div>
                {% endfor %}
              </div>

              <div class="pile-meta-band">
                <span class="pile-title">{{ post.data.title }}</span>
                <div class="pile-meta-line">
                  <span class="meta-item"><span class="meta-label">Year</span> <span class="meta-value">{{ post.date | readableDate("yyyy") }}</span></span>
                  <span class="meta-item"><span class="meta-label">Images</span> <span class="meta-value">{{ projectImages.length }}</span></span>
                  <span class="meta-item"><span class="meta-label">Words</span> <span class="meta-value">{{ wordCount }}</span></span>
                  <span class="meta-item"><span class="meta-label">Type</span> <span class="meta-value">{{ post.data.category or "project" }}</span></span>
                  <span class="meta-item"><span class="meta-label">Tags</span> <span class="meta-value">{% if postTags.length %}{{ postTags | head(2) | join(", ") }}{% else %}none{% endif %}</span></span>
                </div>
              </div>
            </div>
          </a>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

<script>
// Tag filtering functionality
(function() {
  'use strict';
  
  const filterButtons = document.querySelectorAll('.tag-filter-button');
  const projectPiles = document.querySelectorAll('.project-pile');
  const pileImageGroups = document.querySelectorAll('.pile-images');
  const pilesContainer = document.querySelector('.projects-piles-container');

  const SLOW_EFFECTIVE_TYPES = new Set(['slow-2g', '2g']);
  const SLOW_DOWNLINK_MBPS = 1.5;
  const SLOW_RTT_MS = 600;
  const LOW_DEVICE_MEMORY_GB = 2;
  const LOW_CPU_CORES = 2;
  const IMAGE_COUNT_SEED_MULTIPLIER = 97;
  const HASH_MULTIPLIER = 10000;
  const WIDTH_WEIGHT = 0.13;
  const HEIGHT_WEIGHT = 0.17;
  const LAYER_SEED_MULTIPLIER = 23;
  const ASPECT_SEED_MULTIPLIER = 11;
  const SCALE_SEED_OFFSET = 3;
  const WIDTH_SEED_OFFSET = 5;
  const OFFSET_X_SEED_OFFSET = 7;
  const OFFSET_Y_SEED_OFFSET = 11;
  const HEIGHT_SEED_OFFSET = 13;
  const POS_X_SEED_OFFSET = 17;
  const POS_Y_SEED_OFFSET = 19;
  const JITTER_X_SEED_OFFSET = 29;
  const JITTER_Y_SEED_OFFSET = 31;
  const ROTATION_MIN = -14;
  const ROTATION_SPREAD = 28;
  const SCALE_MIN = 0.75;
  const SCALE_SPREAD = 0.35;
  const WIDTH_MIN = 34;
  const WIDTH_SPREAD = 28;
  const HEIGHT_MIN = 32;
  const HEIGHT_SPREAD = 26;
  const POS_X_MIN = 24;
  const POS_X_SPREAD = 52;
  const POS_Y_MIN = 30;
  const POS_Y_SPREAD = 44;
  // Mobile intentionally overscales card dimensions in percentage-of-container units:
  // +38 percentage points with 118%/108% caps to let cards spill past viewport edges while preserving readability.
  const MOBILE_SIZE_BOOST_PCT = 38;
  const MOBILE_WIDTH_CAP = 118;
  const MOBILE_HEIGHT_CAP = 108;
  const OFFSET_X_MIN = -22;
  const OFFSET_X_SPREAD = 44;
  const OFFSET_Y_MIN = -16;
  const OFFSET_Y_SPREAD = 32;

  function deterministicHash(seed) {
    const x = Math.sin(seed) * HASH_MULTIPLIER;
    return x - Math.floor(x);
  }

  function getImageDimensions(img) {
    const attrs = {
      width: img?.getAttribute('width'),
      height: img?.getAttribute('height')
    };
    const width = parseInt(attrs.width, 10) || 0;
    const height = parseInt(attrs.height, 10) || 0;

    return {
      width: img?.naturalWidth || width || 1,
      height: img?.naturalHeight || height || 1
    };
  }

  function hasPositiveNumberAtMost(value, max) {
    const number = Number(value);
    return number > 0 && number <= max;
  }

  function hasNumberAtLeast(value, min) {
    const number = Number(value);
    return number >= min;
  }

  function shouldUseStaticPileLayout() {
    const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
    const prefersReducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    return prefersReducedMotion
      || connection?.saveData
      || SLOW_EFFECTIVE_TYPES.has(connection?.effectiveType)
      || hasPositiveNumberAtMost(connection?.downlink, SLOW_DOWNLINK_MBPS)
      || hasNumberAtLeast(connection?.rtt, SLOW_RTT_MS)
      || hasPositiveNumberAtMost(navigator.deviceMemory, LOW_DEVICE_MEMORY_GB)
      || hasPositiveNumberAtMost(navigator.hardwareConcurrency, LOW_CPU_CORES);
  }

  const useStaticPileLayout = shouldUseStaticPileLayout();
  if (useStaticPileLayout) {
    pilesContainer?.classList.add('pile-effects-disabled');
  }

  let pendingPileGroups = new Set();
  let pileTransformRafId = null;

  function updatePileTransforms(group) {
    const frames = Array.from(group.querySelectorAll('.pile-image'));
    if (!frames.length) {
      return;
    }

    const imageCount = Number(group.dataset.imageCount || frames.length);
    const visibleCount = Math.max(1, Math.min(frames.length, 5));
    const sparseCountBoost = Math.max(0, 4 - visibleCount) * 8;
    let sizeSeed = imageCount * IMAGE_COUNT_SEED_MULTIPLIER;
    frames.forEach((frame, idx) => {
      const img = frame.querySelector('img');
      const dimensions = getImageDimensions(img);
      sizeSeed += ((dimensions.width * WIDTH_WEIGHT + dimensions.height * HEIGHT_WEIGHT) * (idx + 1));
    });

    frames.forEach((frame, idx) => {
      const img = frame.querySelector('img');
      const dimensions = getImageDimensions(img);
      const aspectSeed = dimensions.width / dimensions.height;
      const base = sizeSeed + (idx + 1) * LAYER_SEED_MULTIPLIER + aspectSeed * ASPECT_SEED_MULTIPLIER;
      const fanProgress = visibleCount > 1 ? (idx / (visibleCount - 1)) : 0.5;
      const fanCentering = 20 + (fanProgress * 60);
      const jitterX = -9 + deterministicHash(base + JITTER_X_SEED_OFFSET) * 18;
      const jitterY = -7 + deterministicHash(base + JITTER_Y_SEED_OFFSET) * 14;

      const rotation = ROTATION_MIN + deterministicHash(base) * ROTATION_SPREAD;
      const scale = SCALE_MIN + deterministicHash(base + SCALE_SEED_OFFSET) * SCALE_SPREAD;
      const width = WIDTH_MIN + sparseCountBoost + deterministicHash(base + WIDTH_SEED_OFFSET) * WIDTH_SPREAD;
      const height = HEIGHT_MIN + (sparseCountBoost * 0.85) + deterministicHash(base + HEIGHT_SEED_OFFSET) * HEIGHT_SPREAD;
      const posX = fanCentering + jitterX;
      const posY = (POS_Y_MIN + deterministicHash(base + POS_Y_SEED_OFFSET) * (POS_Y_SPREAD * 0.65)) + jitterY;
      const offsetX = OFFSET_X_MIN + deterministicHash(base + OFFSET_X_SEED_OFFSET) * OFFSET_X_SPREAD;
      const offsetY = OFFSET_Y_MIN + deterministicHash(base + OFFSET_Y_SEED_OFFSET) * OFFSET_Y_SPREAD;

      frame.style.setProperty('--rotation', rotation.toFixed(2) + 'deg');
      frame.style.setProperty('--scale', scale.toFixed(3));
      frame.style.setProperty('--w', width.toFixed(1) + '%');
      frame.style.setProperty('--h', height.toFixed(1) + '%');
      frame.style.setProperty('--w-mobile', Math.min(MOBILE_WIDTH_CAP, width + MOBILE_SIZE_BOOST_PCT).toFixed(1) + '%');
      frame.style.setProperty('--h-mobile', Math.min(MOBILE_HEIGHT_CAP, height + MOBILE_SIZE_BOOST_PCT).toFixed(1) + '%');
      frame.style.setProperty('--pos-x', posX.toFixed(1) + '%');
      frame.style.setProperty('--pos-y', posY.toFixed(1) + '%');
      frame.style.setProperty('--offset-x', offsetX.toFixed(1) + 'px');
      frame.style.setProperty('--offset-y', offsetY.toFixed(1) + 'px');
    });
  }

  function schedulePileTransform(group) {
    pendingPileGroups.add(group);
    if (pileTransformRafId) {
      // The pending RAF will flush every group currently in pendingPileGroups.
      return;
    }

    pileTransformRafId = requestAnimationFrame(() => {
      pendingPileGroups.forEach(updatePileTransforms);
      pendingPileGroups.clear();
      pileTransformRafId = null;
    });
  }

  function initializePileLayouts() {
    if (useStaticPileLayout) {
      return;
    }

    pileImageGroups.forEach(group => {
      const scheduleGroupTransform = schedulePileTransform.bind(null, group);
      updatePileTransforms(group);
      group.querySelectorAll('img').forEach(img => {
        if (!img.complete) {
          img.addEventListener('load', scheduleGroupTransform, { once: true });
        }
      });
    });
  }
  
  filterButtons.forEach(button => {
    button.addEventListener('click', function() {
      const selectedTag = this.dataset.tag;
      
      // Update active button
      filterButtons.forEach(btn => btn.classList.remove('active'));
      this.classList.add('active');
      
      // Filter projects
      projectPiles.forEach(pile => {
        if (selectedTag === 'all') {
          pile.style.display = '';
        } else {
          const pileTags = pile.dataset.tags;
          if (pileTags.includes('tag-' + selectedTag)) {
            pile.style.display = '';
          } else {
            pile.style.display = 'none';
          }
        }
      });
    });
  });

  initializePileLayouts();
})();
</script>
