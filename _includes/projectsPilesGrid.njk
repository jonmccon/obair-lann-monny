{# Piled projects component with tag filtering #}
{# Displays projects as randomly stacked piles grouped by tags #}

<div class="projects-piles-container">
  {# Tag filter buttons #}
  <div class="tag-filter-bar">
    <button class="tag-filter-button active" data-tag="all">All Projects</button>
    {% set allTags = collections.projects | getAllTags | filterTagList | sort %}
    {% for tag in allTags %}
      <button class="tag-filter-button" data-tag="{{ tag | slugify }}">{{ tag }}</button>
    {% endfor %}
  </div>

  {# Projects piles grid #}
  <div class="projects-piles-grid">
    {% for post in collections.projects | reverse %}
      {# Gather images for this post #}
      {% set projectImages = [] %}
      {% for image in collections.images %}
        {% if image.url == post.url %}
          {% set projectImages = projectImages.concat([image.src]) %}
        {% endif %}
      {% endfor %}
      
      {% if projectImages.length > 0 %}
        {# Get tags for filtering #}
        {% set postTags = post.data.tags | filterTagList %}
        {% set tagClasses = "" %}
        {% for tag in postTags %}
          {% set tagClasses = tagClasses + " tag-" + (tag | slugify) %}
        {% endfor %}
        
        <div class="project-pile" data-tags="{{ tagClasses }}">
          <a href="{{ post.url }}" class="pile-link" data-project-link>
            <div class="pile-container">
              <div class="pile-meta-band">
                <span class="pile-title">{{ post.data.title }}</span>
                <div class="pile-meta-line">
                  <span class="meta-item"><span class="meta-label">Year</span> <span class="meta-value">{{ post.date | readableDate("yyyy") }}</span></span>
                  <span class="meta-item"><span class="meta-label">Images</span> <span class="meta-value">{{ projectImages.length }}</span></span>
                  <span class="meta-item"><span class="meta-label">Words</span> <span class="meta-value meta-word-count">--</span></span>
                  <span class="meta-item"><span class="meta-label">Type</span> <span class="meta-value">{{ post.data.category or "project" }}</span></span>
                  <span class="meta-item"><span class="meta-label">Tags</span> <span class="meta-value">{% if postTags.length %}{{ postTags | head(2) | join(", ") }}{% else %}none{% endif %}</span></span>
                </div>
              </div>

              <div class="pile-images"
                   data-image-count="{{ projectImages.length }}"
                   data-word-source="{{ (post.templateContent | striptags | replace('\n', ' ') | replace('\r', ' ') | trim) | escape }}">
                {% for img in projectImages | head(5) %}
                  <div class="pile-image"
                       data-layer-index="{{ loop.index0 }}"
                       style="--z-index: {{ 10 - loop.index0 }};">
                    <img src="{{ img }}" alt="{{ post.data.title }}" loading="lazy">
                  </div>
                {% endfor %}
              </div>
            </div>
          </a>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

<script>
// Tag filtering functionality
(function() {
  'use strict';
  
  const filterButtons = document.querySelectorAll('.tag-filter-button');
  const projectPiles = document.querySelectorAll('.project-pile');
  const pileImageGroups = document.querySelectorAll('.pile-images');

  function seededRandom(seed) {
    const x = Math.sin(seed) * 10000;
    return x - Math.floor(x);
  }

  function updatePileTransforms() {
    pileImageGroups.forEach(group => {
      const frames = Array.from(group.querySelectorAll('.pile-image'));
      if (!frames.length) {
        return;
      }

      const imageCount = Number(group.dataset.imageCount || frames.length);
      const wordSource = group.dataset.wordSource || '';
      const wordCount = wordSource ? wordSource.split(/\s+/).filter(Boolean).length : 0;
      const wordCountNode = group.closest('.pile-container')?.querySelector('.meta-word-count');
      if (wordCountNode) {
        wordCountNode.textContent = String(wordCount);
      }

      let sizeSeed = imageCount * 97;
      frames.forEach((frame, idx) => {
        const img = frame.querySelector('img');
        const w = img?.naturalWidth || 0;
        const h = img?.naturalHeight || 0;
        sizeSeed += ((w * 0.13 + h * 0.17) * (idx + 1));
      });

      frames.forEach((frame, idx) => {
        const img = frame.querySelector('img');
        const w = img?.naturalWidth || 1;
        const h = img?.naturalHeight || 1;
        const aspectSeed = w / h;
        const base = sizeSeed + (idx + 1) * 23 + aspectSeed * 11;

        const rotation = -14 + seededRandom(base) * 28;
        const scale = 0.64 + seededRandom(base + 3) * 0.52;
        const offsetX = -22 + seededRandom(base + 7) * 44;
        const offsetY = -16 + seededRandom(base + 11) * 32;

        frame.style.setProperty('--rotation', rotation.toFixed(2) + 'deg');
        frame.style.setProperty('--scale', scale.toFixed(3));
        frame.style.setProperty('--offset-x', offsetX.toFixed(1) + 'px');
        frame.style.setProperty('--offset-y', offsetY.toFixed(1) + 'px');
      });
    });
  }

  function initializePileLayouts() {
    updatePileTransforms();
    pileImageGroups.forEach(group => {
      group.querySelectorAll('img').forEach(img => {
        if (!img.complete) {
          img.addEventListener('load', updatePileTransforms, { once: true });
        }
      });
    });
  }
  
  filterButtons.forEach(button => {
    button.addEventListener('click', function() {
      const selectedTag = this.dataset.tag;
      
      // Update active button
      filterButtons.forEach(btn => btn.classList.remove('active'));
      this.classList.add('active');
      
      // Filter projects
      projectPiles.forEach(pile => {
        if (selectedTag === 'all') {
          pile.style.display = '';
        } else {
          const pileTags = pile.dataset.tags;
          if (pileTags.includes('tag-' + selectedTag)) {
            pile.style.display = '';
          } else {
            pile.style.display = 'none';
          }
        }
      });
    });
  });

  initializePileLayouts();
})();
</script>
