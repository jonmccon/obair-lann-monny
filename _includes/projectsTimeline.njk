{# Timeline component for displaying projects chronologically #}
{# Projects are arranged as vertical columns in a horizontal timeline #}
{# Self-initiated projects appear above the center line, client work below #}

{% set sortedProjects = collections.projects | sort(false, false, 'date') %}

<div class="timeline-wrapper">
  <div class="project-timeline">
    {% for post in sortedProjects %}
      {% if not post.data.timelineExclude %}
        {% set pType = post.data.projectType or 'self' %}
        {% set bgClass = '' %}
        {% if post.data.bgColor %}{% set bgClass = ' tl-bg-' + post.data.bgColor %}{% endif %}

        <div class="timeline-col{{ bgClass }}">
          {# Top cell — self-initiated project content grows upward from the axis #}
          <div class="timeline-cell timeline-cell-top">
            {% if pType != 'client' %}
            <a href="{{ post.url }}" class="timeline-col-link">
              <span class="timeline-col-title">{{ post.data.title }}</span>
              {% for image in collections.images %}
                {% if image.url == post.url %}
                  <img src="{{ image.src }}" alt="{{ image.alt }}" loading="lazy" class="timeline-col-img">
                {% endif %}
              {% endfor %}
              <span class="timeline-col-synopsis">{{ post.data.description }}</span>
            </a>
            {% endif %}
          </div>

          {# Center axis marker with year #}
          <div class="timeline-axis-marker">
            <span class="timeline-year">{{ post.date | readableDate("yyyy") }}</span>
          </div>

          {# Bottom cell — client project content grows downward from the axis #}
          <div class="timeline-cell timeline-cell-bottom">
            {% if pType == 'client' %}
            <a href="{{ post.url }}" class="timeline-col-link">
              <span class="timeline-col-title">{{ post.data.title }}</span>
              {% for image in collections.images %}
                {% if image.url == post.url %}
                  <img src="{{ image.src }}" alt="{{ image.alt }}" loading="lazy" class="timeline-col-img">
                {% endif %}
              {% endfor %}
              <span class="timeline-col-synopsis">{{ post.data.description }}</span>
            </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>
