---
layout: layouts/base.njk
---
{#- Include PhotoSwipe CSS on gallery pages #}
{%- css %}{% include "public/css/photoswipe-gallery.css" %}{% endcss %}
<link rel="stylesheet" href="/css/photoswipe.css">

<article class="gallery-page page-shell page-shell--wide section-stack">
  <header class="gallery-header page-header">
    <h1>{{ title }}</h1>

    <ul class="post-metadata meta-list">
      <li><time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time></li>
    </ul>

    {% if description %}
    <p class="gallery-description">{{ description }}</p>
    {% endif %}
  </header>

  <div class="gallery-body rich-text">
    {{ content | safe }}
  </div>

  {%- set isPrimaryCategory = false %}
  {%- for category in photoCategories %}
    {%- if category.url == page.url %}
      {%- set isPrimaryCategory = true %}
    {%- endif %}
  {%- endfor %}

  {%- if isPrimaryCategory %}
  <section class="gallery-siblings section-stack">
    <h2>Explore Galleries</h2>
    <div class="galleries-grid galleries-grid--siblings">
      {%- for category in photoCategories %}
        <article class="gallery-card{% if category.url == page.url %} gallery-card--current{% endif %}">
          {% if category.url == page.url %}
            <div class="gallery-card-link" aria-current="page">
              <div class="gallery-card-image">
                {% if category.previewImages and category.previewImages.length %}
                  <div class="gallery-card-jumble" aria-hidden="true">
                    {# Decorative card collage: title and description already provide the accessible label. #}
                    {% for previewImage in category.previewImages %}
                      {% if loop.index <= 5 %}
                        <div class="gallery-card-jumble-item gallery-card-jumble-item--{{ loop.index }}">
                          {% image previewImage, "" %}
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                {% else %}
                  {% image category.cover, category.title %}
                {% endif %}
              </div>
              <div class="gallery-card-content">
                <h3 class="gallery-card-title">{{ category.title }}</h3>
                <p class="gallery-card-current-label">Current gallery</p>
              </div>
            </div>
          {% else %}
            <a href="{{ category.url }}" class="gallery-card-link">
              <div class="gallery-card-image">
                {% if category.previewImages and category.previewImages.length %}
                  <div class="gallery-card-jumble" aria-hidden="true">
                    {# Decorative card collage: title and description already provide the accessible label. #}
                    {% for previewImage in category.previewImages %}
                      {% if loop.index <= 5 %}
                        <div class="gallery-card-jumble-item gallery-card-jumble-item--{{ loop.index }}">
                          {% image previewImage, "" %}
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                {% else %}
                  {% image category.cover, category.title %}
                {% endif %}
              </div>
              <div class="gallery-card-content">
                <h3 class="gallery-card-title">{{ category.title }}</h3>
              </div>
            </a>
          {% endif %}
        </article>
      {%- endfor %}
    </div>
  </section>
  {%- endif %}
</article>
