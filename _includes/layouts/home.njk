---
layout: layouts/base.njk
---
{% if page.url == "/" %}
{% set about = collections.aboutPages | first %}
<p class="homepage-headline">Design, photography, internet, classrooms, studios, food, boats, tools, process, and everything being made.</p>

<section class="home-newspaper" aria-label="Homepage newspaper of projects and posts">
  {% if about %}
  <article class="newspaper-card newspaper-card-about">
    <a class="newspaper-card-link" href="{{ about.url }}" aria-label="{{ about.data.title }}"></a>
    <img src="https://github.com/user-attachments/assets/c956ad3d-f0ab-4737-a3c6-e3bd8ff7038b" alt="Jonny McConnell portrait" class="newspaper-avatar">
    <div class="newspaper-kicker">About</div>
    <h1>{{ about.data.title }}</h1>
    <div class="newspaper-card-body">
      {{ about.templateContent | safe }}
    </div>
  </article>
  {% endif %}

  {% for post in collections.projects | reverse %}
  <article class="newspaper-card newspaper-card-project{% if post.templateContent | wordCount > 180 %} newspaper-card-wide{% endif %}">
    <a class="newspaper-card-link" href="{{ post.url }}" aria-label="{{ post.data.title }}"></a>
    <div class="newspaper-kicker">Project</div>
    <h2>{{ post.data.title }}</h2>
    {% if post.data.description %}<p class="newspaper-description">{{ post.data.description }}</p>{% endif %}
    {% if post.data.images %}
    <div class="newspaper-images">
      {% for image in post.data.images %}
        {% homepageImage image.src, image.alt or post.data.title %}
      {% endfor %}
    </div>
    {% endif %}
    <div class="newspaper-card-body">
      {{ post.templateContent | stripHomepageMedia | safe }}
    </div>
  </article>
  {% endfor %}

  {% for post in collections.process | reverse %}
  <article class="newspaper-card newspaper-card-process{% if post.templateContent | wordCount > 220 %} newspaper-card-tall{% endif %}">
    <a class="newspaper-card-link" href="{{ post.url }}" aria-label="{{ post.data.title }}"></a>
    <div class="newspaper-kicker">Post</div>
    <h2>{{ post.data.title }}</h2>
    {% if post.data.description %}<p class="newspaper-description">{{ post.data.description }}</p>{% endif %}
    {% if post.data.images %}
    <div class="newspaper-images">
      {% for image in post.data.images %}
        {% homepageImage image.src, image.alt or post.data.title %}
      {% endfor %}
    </div>
    {% endif %}
    <div class="newspaper-card-body">
      {{ post.templateContent | stripHomepageMedia | safe }}
    </div>
  </article>
  {% endfor %}
</section>
{% endif %}

{{ content | safe }}
