---
layout: layouts/base.njk
---
{% if page.url == "/" %}
<section class="homepage-main-header" aria-label="Homepage header">
  <div class="homepage-main-avatar">
    {% image profile.portraitUrl, "Jonny McConnell portrait", [172], "172px" %}
  </div>
  <p class="homepage-headline">{{ profile.headline }}</p>
  <p class="homepage-about">{{ profile.aboutBio }}</p>
</section>

<section class="home-newspaper" aria-label="Homepage newspaper of projects and posts">
  {% for post in collections.projects | reverse %}
  <article class="newspaper-card newspaper-card-project{% if post.templateContent | wordCount > profile.wideCardWordThreshold %} newspaper-card-wide{% endif %}">
    <a class="newspaper-card-link" href="{{ post.url }}" aria-label="{{ post.data.title }}"></a>
    <h2>{{ post.data.title }}</h2>
    {% if post.data.description %}<p class="newspaper-description">{{ post.data.description }}</p>{% endif %}
    {% if post.data.images %}
    <div class="newspaper-images">
      {% for image in post.data.images %}
        {% homepageImage image.src, image.alt | default(post.data.title) %}
      {% endfor %}
    </div>
    {% endif %}
    <div class="newspaper-card-body">
      {{ post.templateContent | stripHomepageMedia | safe }}
    </div>
  </article>
  {% endfor %}

  {% for post in collections.process | reverse %}
  <article class="newspaper-card newspaper-card-process{% if post.templateContent | wordCount > profile.tallCardWordThreshold %} newspaper-card-tall{% endif %}">
    <a class="newspaper-card-link" href="{{ post.url }}" aria-label="{{ post.data.title }}"></a>
    <h2>{{ post.data.title }}</h2>
    {% if post.data.description %}<p class="newspaper-description">{{ post.data.description }}</p>{% endif %}
    {% if post.data.images %}
    <div class="newspaper-images">
      {% for image in post.data.images %}
        {% homepageImage image.src, image.alt | default(post.data.title) %}
      {% endfor %}
    </div>
    {% endif %}
    <div class="newspaper-card-body">
      {{ post.templateContent | stripHomepageMedia | safe }}
    </div>
  </article>
  {% endfor %}
</section>
{% endif %}

{{ content | safe }}
