---
layout: layouts/base.njk
---
{% if page.url == "/" %}
{% set about = collections.aboutPages | first %}
<p class="homepage-headline">{{ profile.headline }}</p>

<section class="home-newspaper" aria-label="Homepage newspaper of projects and posts">
  {% if about %}
  <article class="newspaper-card newspaper-card-about">
    <a class="newspaper-card-link" href="{{ about.url }}" aria-label="{{ about.data.title }}"></a>
    <img src="{{ profile.portraitUrl }}" alt="Jonny McConnell portrait" class="newspaper-avatar">
    <div class="newspaper-kicker">About</div>
    <h1>{{ about.data.title }}</h1>
    <div class="newspaper-card-body">
      {{ about.templateContent | safe }}
    </div>
  </article>
  {% endif %}

  {% for post in collections.projects | reverse %}
  {% set postExcerpt = post.templateContent | excerpt(38) %}
  <article class="newspaper-card newspaper-card-project{% if postExcerpt | wordCount > profile.wideCardWordThreshold %} newspaper-card-wide{% endif %}">
    <a class="newspaper-card-link" href="{{ post.url }}" aria-label="{{ post.data.title }}"></a>
    <h2>{{ post.data.title }}</h2>
    {% if post.data.description %}<p class="newspaper-description">{{ post.data.description }}</p>{% endif %}
    {% if post.data.images %}
    <div class="newspaper-images">
      {% for image in post.data.images %}
        {% homepageImage image.src, image.alt | default(post.data.title) %}
      {% endfor %}
    </div>
    {% endif %}
    {% if postExcerpt %}
    <div class="newspaper-card-body">
      <p>{{ postExcerpt }}</p>
    </div>
    {% endif %}
  </article>
  {% endfor %}

  {% for post in collections.process | reverse %}
  {% set postExcerpt = post.templateContent | excerpt(38) %}
  <article class="newspaper-card newspaper-card-process{% if postExcerpt | wordCount > profile.tallCardWordThreshold %} newspaper-card-tall{% endif %}">
    <a class="newspaper-card-link" href="{{ post.url }}" aria-label="{{ post.data.title }}"></a>
    <h2>{{ post.data.title }}</h2>
    {% if post.data.description %}<p class="newspaper-description">{{ post.data.description }}</p>{% endif %}
    {% if post.data.images %}
    <div class="newspaper-images">
      {% for image in post.data.images %}
        {% homepageImage image.src, image.alt | default(post.data.title) %}
      {% endfor %}
    </div>
    {% endif %}
    {% if postExcerpt %}
    <div class="newspaper-card-body">
      <p>{{ postExcerpt }}</p>
    </div>
    {% endif %}
  </article>
  {% endfor %}
</section>
{% endif %}

{{ content | safe }}
