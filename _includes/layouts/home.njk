---
layout: layouts/base.njk
---
{# Post listing, links list, and projects list have been archived in home-archive.njk #}

{# Only show image grid on the actual homepage #}
{% if page.url == "/" %}
<div class="homepage-shell">
<div class="image-grid">
  {% for item in collections.images | reverse %}
    <div class="image-item">
      <a href="{{ item.url }}">
        <img src="{{ item.src }}" alt="{{ item.alt }}"{% if loop.first %} loading="eager" fetchpriority="high"{% else %} loading="lazy"{% endif %} decoding="async">
      </a>
    </div>
  {% endfor %}
</div>

{# Preload first few critical images for instant interaction #}
{% set criticalImages = collections.images | reverse | slice(0, 3) %}
{% for item in criticalImages %}
<link rel="preload" as="image" href="{{ item.src }}">
{% endfor %}

{# Hero section: portrait photo + about description #}
<section class="hero-section">
  <div class="hero-portrait">
    <img src="https://github.com/user-attachments/assets/c956ad3d-f0ab-4737-a3c6-e3bd8ff7038b" alt="Jonny McConnell portrait" class="portrait-photo">
  </div>
  <div class="hero-about">
    <p>Jonny is a creative with one foot in design, one in photography, one in building internet & one in the classroom. He's a tinkerer, a sailor, a chef and generally just wants to learn how things are made. A graduate of Western Washington University, a former board member of AIGA Seattle, a former mascot of the Seattle Sounders, Jonny balances time between freelance, maintaining the Seattle Creative Directory and developing machine aided printmaking from his studio on Whidbey Island.</p>

    <h2>Contact</h2>
    <ul>
      <li>Email: hello@jonmccon.com</li>
      <li>Location: Whidbey Island</li>
      <li>Social: <a href="https://www.instagram.com/jonmccon">@jonmccon</a></li>
    </ul>
  </div>
</section>

<section class="homepage-podcast">
  <h2>Seattle Creative Podcast</h2>
  <div class="homepage-podcast-players">
    <iframe
      src="https://player.simplecast.com/1fcc9781-6d54-4b27-8a00-9b511ae09bf5?dark=false"
      title="Seattle Creative podcast player - Episode 1"
      loading="lazy"
      allow="autoplay"
    ></iframe>
    <iframe
      src="https://player.simplecast.com/a8c63034-9b6c-4d56-b3ed-e440f6a3e031?dark=false"
      title="Seattle Creative podcast player - Episode 2"
      loading="lazy"
      allow="autoplay"
    ></iframe>
    <iframe
      src="https://player.simplecast.com/f16ee7eb-9281-40d6-8401-085334af24f8?dark=false"
      title="Seattle Creative podcast player - Episode 3"
      loading="lazy"
      allow="autoplay"
    ></iframe>
  </div>
</section>

{# Projects grid under the fold #}
<section class="homepage-projects">
  <h2>Projects</h2>
  {% set projectItems = collections.featuredProjects %}
  {% include "projectsGrid.njk" %}
</section>
</div>
{% endif %}

{{ content | safe }}
